----------------------------- MODULE CounterLemma -----------------------------
EXTENDS Naturals, TLC

(***************************************************************************)
(* Simple counter system                                                   *)
(***************************************************************************)

VARIABLE x

Init == x = 0

Next == x' = x + 1

(***************************************************************************)
(* With x >= 2 we get                                                      *)
(*                                                                         *)
(* [ERROR]: Could not prove or check:                                      *)
(*            ASSUME NEW VARIABLE x,                                       *)
(*                   Init == x = 0,                                        *)
(*                   Inv == x >= 2                                         *)
(*            PROVE  Init => Inv                                           *)
(***************************************************************************)

Inv == x >= 0

Spec == Init /\ [][Next]_<<x>>

-----------------------------------------------------------------------------
INSTANCE TLAPS

LEMMA OK == Spec => []Inv
<1>1. Init => Inv BY DEF Init, Inv
<1>2. Inv /\ [Next]_<<x>> => Inv'
<1>3. QED BY <1>1, <1>2, PTL DEF Spec

=============================================================================
